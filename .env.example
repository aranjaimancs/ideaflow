# Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Trello API credentials
# Get these from https://trello.com/power-ups/admin -> create a Power-Up -> API key page
TRELLO_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_api_token_here

# The ID of the Trello list to watch for new idea cards
# See README for how to find list IDs
TRELLO_IDEAS_LIST_ID=your_ideas_list_id_here

# The ID of the Trello list to move processed cards into (used in later pipeline stages)
TRELLO_DONE_LIST_ID=your_done_list_id_here

# GitHub credentials for cloning idea-mvps and opening PRs
# Token needs: repo scope (read+write to the idea-mvps repo)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username_here
IDEA_MVPS_REPO=idea-mvps
